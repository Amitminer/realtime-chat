########################################
# Required secrets / runtime variables
########################################
# Shared secret used for auth and key derivation (REQUIRED)
SERVER_PASSWORD=changeme

# Public WebSocket URL exposed to the browser via /config.js
# Local dev:
WS_URL=ws://localhost:9001
# Production example (behind TLS / reverse proxy):
# WS_URL=wss://ws.example.com

########################################
# Optional overrides (uncomment to use)
########################################
# Backend WebSocket server:
# BACKEND_HOST=0.0.0.0
# BACKEND_PORT=9001
# BACKEND_BIND_ADDR=0.0.0.0:9001

# Static server (serves frontend/ and /config.js):
# FRONTEND_HOST=0.0.0.0
# FRONTEND_PORT=8080
# ROOT_DIR=frontend
# LIVE_RELOAD=true
